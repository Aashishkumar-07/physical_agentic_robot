<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <material name = "muted-reddish-brown">
        <color rgba = "0.5 0.2 0.2 1"/>
    </material>

    <material name = "grey">
        <color rgba = "0.5 0.5 0.5 1"/>
    </material>

    <material name = "black">
        <color rgba = "0 0 0 1"/>
    </material>


    <material name="yellow">
        <color rgba="1.0 1.0 0.0 1.0"/>
    </material>

    <material name="orange">
        <color rgba="0.953 0.612 0.071 1.0"/>
    </material>


    <!-- xacro macro (functions) for inertia -->
    <xacro:macro name="box_inertia" params="m x y z o_xyz o_rpy">
        <inertial>
            <mass value="${m}"/>
            <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
            <inertia ixx="${(m/12) * (y**2 + z**2)}" ixy="0" ixz="0"
                     iyy="${(m/12) * (x**2 + z**2)}" iyz="0"
                     izz="${(m/12) * (x**2 + y**2)}"
            />
        </inertial>
    </xacro:macro>

    <xacro:macro name="solid_sphere_inertia" params="m r o_xyz o_rpy">
        <inertial>
            <mass value="${m}"/>
            <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
            <inertia ixx="${(2/5) * (m*(r**2))}" ixy="0" ixz="0"
                     iyy="${(2/5) * (m*(r**2))}" iyz="0"
                     izz="${(2/5) * (m*(r**2))}"
            />
        </inertial>
    </xacro:macro>

    <xacro:macro name="solid_cylinder_inertia" params="m r h o_xyz o_rpy">
        <inertial>
            <mass value="${m}"/>
            <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
            <inertia ixx="${(m/12) * ((3*(r**2)) + h**2)}" ixy="0" ixz="0"
                     iyy="${(m/12) * ((3*(r**2)) + h**2)}" iyz="0"
                     izz="${(m/2) * (r**2)}"
            />
        </inertial>
    </xacro:macro>

</robot>
